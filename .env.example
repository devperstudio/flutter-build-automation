# API Configuration
API_BASE_URL=https://your-api-server.com
BOT_API_KEY=your_bot_api_key_here

# Polling Configuration
POLL_INTERVAL_SECONDS=10
REQUEST_TIMEOUT_SECONDS=30

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_QUEUE_NAME=apk_build_queue

# Flutter Project Configuration
PROJECT_PATH=/home/builder/login_app
GIT_BRANCH=main

# APK Output Configuration
APK_OUTPUT_DIR=/home/builder/apk-outputs

# Logging
LOG_LEVEL=INFO
LOG_DIR=/home/builder/automation/logs
